# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7613057488:AAGccC3R7RWZ4KCOh-58L_5L87YtTFllYuk

# ── MLX Models ────────────────────────────────────────────────────────────────
# Chat + task routing LLM (Qwen2.5 bilingual zh/en)
MLX_CHAT_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit

# Vision/video summarisation (upgrade to 7B if RAM permits)
MLX_VL_MODEL=mlx-community/Qwen2.5-VL-3B-Instruct-4bit

# Speech-to-text (upgrade to whisper-large-v3-turbo for better accuracy)
MLX_WHISPER_MODEL=mlx-community/whisper-small-mlx

# ── TTS ───────────────────────────────────────────────────────────────────────
# Path to a 6+ second reference WAV for XTTS-v2 voice cloning.
# If the file exists it takes priority and the voice will be cloned from it.
SPEAKER_WAV_PATH=assets/speaker.wav

# Named built-in XTTS-v2 speaker used when SPEAKER_WAV_PATH file is absent.
# 58 voices available, e.g.: Claribel Dervla, Daisy Studious, Gracie Wise,
# Tammie Ema, Alison Dietlinde, Ana Florence, Annmarie Nele, Brenda Stern ...
# Leave empty to use the default (Claribel Dervla).
SPEAKER_NAME=Zofija Kendrick

# Speech speed multiplier: 1.0 = normal, >1.0 = faster, <1.0 = slower
SPEECH_SPEED=1.06

# Speaking emotion (forwarded to TTS API; XTTS-v2 does not apply it currently)
SPEECH_EMOTION=happy

# Accept Coqui XTTS-v2 Terms of Service (required for non-interactive/service use)
# Review the terms at: https://coqui.ai/cpml.txt
COQUI_TOS_AGREED=1

# ── Embeddings ────────────────────────────────────────────────────────────────
# Multilingual (zh + en), dim=384
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# ── External APIs ─────────────────────────────────────────────────────────────
# Required only if Codex task routing is used
OPENAI_API_KEY=

# ── Tool System ───────────────────────────────────────────────────────────────
# Directory watched for hot-loaded user tools (no restart needed)
TOOLS_CUSTOM_DIR=ella/tools/custom

# Max ReAct tool-call iterations per message batch
MAX_TOOL_ROUNDS=5

# ── Memory ────────────────────────────────────────────────────────────────────
# Redis TTL for JobGoal (seconds) — 24h default
GOAL_TTL_SECONDS=86400

# Number of Qdrant results recalled at job start
KNOWLEDGE_RECALL_TOP_K=5
